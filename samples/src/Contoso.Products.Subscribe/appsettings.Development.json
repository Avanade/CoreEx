{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Azure": "Warning",
      "Microsoft": "Warning",
      "Npgsql": "Warning",
      "ZiggyCreature": "Warning",
      "StackExchange": "Warning",
      "Azure.Messaging.ServiceBus": "Critical",
      "CoreEx.Azure.Messaging.ServiceBus": "Warning"
    }
  },
  "Aspire": {
    "Npgsql": {
      "ConnectionString": "Server=127.0.0.1;Database=contoso;Username=postgres;Password=yourStrong#!Password"
    },
    "StackExchange": {
      "Redis": {
        "ConnectionString": "localhost:6379",
        "ConfigurationOptions": {
          "ConnectTimeout": 3000,
          "ConnectRetry": 2
        }
      }
    },
    "Azure": {
      "Messaging": {
        "ServiceBus": {
          "ConnectionString": "Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;",
          "QueueOrTopicName": "contoso",
          "SubscriptionName": "products"
        }
      }
    }
  }
}