<Project Sdk="Microsoft.NET.Sdk">

  <!-- Targeting & Language Defaults -->
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
  </PropertyGroup>

  <!-- Versioning (defined in /Version.props at repo root) -->
  <Import Project="..\..\Version.props" />

  <!-- Build Quality -->
  <PropertyGroup>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Strong Name Signing -->
  <PropertyGroup>
    <AssemblyOriginatorKeyFile>..\..\strong-name-key.snk</AssemblyOriginatorKeyFile>
    <SignAssembly>true</SignAssembly>
  </PropertyGroup>

  <!-- NuGet Package Metadata -->
  <PropertyGroup>
    <Authors>Avanade</Authors>
    <Company>Avanade (https://www.avanade.com/)</Company>
    <Copyright>Copyright (c) Avanade.</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>Logo256x256.png</PackageIcon>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/Avanade/CoreEx</RepositoryUrl>
    <PackageProjectUrl>https://github.com/Avanade/CoreEx</PackageProjectUrl>
  </PropertyGroup>

  <!-- Roslyn Analyzer Configuration -->
  <PropertyGroup>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <OutputItemType>Analyzer</OutputItemType>
    
    <!-- Not packed standalone; bundled into CoreEx package. -->
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <GetTargetPathDependsOn>$(GetTargetPathDependsOn);GetDependencyTargetPaths</GetTargetPathDependsOn>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Templates\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="bin\**" />
    <EmbeddedResource Remove="bin\**" />
    <None Remove="bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Handlebars.Net" PrivateAssets="all" GeneratePathProperty="true" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
    <PackageReference Include="Pluralize.NET" PrivateAssets="all" GeneratePathProperty="true" />
    <!-- StrongNamer required for strong-naming Pluralize.NET which is not signed. -->
    <PackageReference Include="StrongNamer" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="bin\Debug\netstandard2.0\\CoreEx.Generator.dll" />
  </ItemGroup>

   
  <Target Name="GetDependencyTargetPaths">
    <ItemGroup>
      <TargetPathWithTargetPlatformMoniker Include="$(PkgHandlebars_Net)\lib\netstandard2.0\Handlebars.dll" IncludeRuntimeDependency="false" />
      <TargetPathWithTargetPlatformMoniker Include="$(PkgPluralize_NET)\lib\netstandard2.0\Pluralize.NET.dll" IncludeRuntimeDependency="false" />
    </ItemGroup>
  </Target>

  <Target Name="_ForceAllResourcesToMainAssembly" AfterTargets="SplitResourcesByCulture">
    <ItemGroup>
      <EmbeddedResource>
        <Culture />
        <WithCulture>false</WithCulture>
      </EmbeddedResource>
    </ItemGroup>
  </Target>

  <PropertyGroup>
    <!-- Copies all resolved deps to bin/; required for Release pack (CoreEx.csproj bundles Pluralize.NET.dll from generator output). -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!-- Explicitly copy only what we need; even if the above is ignored. -->
  <Target Name="CopyAnalyzerDeps" AfterTargets="Build">
    <ItemGroup>
      <_AnalyzerDep Include="$(PkgPluralize_NET)\lib\netstandard2.0\Pluralize.NET.dll" />
      <_AnalyzerDep Include="$(PkgHandlebars_Net)\lib\netstandard2.0\Handlebars.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_AnalyzerDep)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" />
    <!-- Optional: log what got copied so you can confirm in the build output -->
    <Message Importance="High" Text="Copied analyzer deps: @(_AnalyzerDep)" />
  </Target>

</Project>
