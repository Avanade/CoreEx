      <_AiFile Include="$(_RepoRoot).github/skills/coreex-policy/references/workflow.md" DestSubPath=".github/skills/coreex-policy/references/workflow.md" />
      <_AiFile Include="$(_RepoRoot).github/prompts/coreex-adapter.prompt.md" DestSubPath=".github/prompts/coreex-adapter.prompt.md" />
