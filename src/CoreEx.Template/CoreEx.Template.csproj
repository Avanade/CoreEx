      <_AiFile Include="$(_RepoRoot).github/skills/coreex-api/references/workflow.md" DestSubPath=".github/skills/coreex-api/references/workflow.md" />
      <_AiFile Include="$(_RepoRoot).github/prompts/coreex-subscriber.prompt.md" DestSubPath=".github/prompts/coreex-subscriber.prompt.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-subscriber/SKILL.md" DestSubPath=".github/skills/coreex-subscriber/SKILL.md" />
