      <_AiFile Include="$(_RepoRoot).github/skills/coreex-validator/SKILL.md" DestSubPath=".github/skills/coreex-validator/SKILL.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-validator/references/workflow.md" DestSubPath=".github/skills/coreex-validator/references/workflow.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-repository/SKILL.md" DestSubPath=".github/skills/coreex-repository/SKILL.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-repository/references/workflow.md" DestSubPath=".github/skills/coreex-repository/references/workflow.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-app-service/SKILL.md" DestSubPath=".github/skills/coreex-app-service/SKILL.md" />
      <_AiFile Include="$(_RepoRoot).github/skills/coreex-app-service/references/workflow.md" DestSubPath=".github/skills/coreex-app-service/references/workflow.md" />
      <_AiFile Include="$(_RepoRoot).github/agents/coreex-expert.agent.md" DestSubPath=".github/agents/coreex-expert.agent.md" />
      <_AiFile Include="$(_RepoRoot).claude/commands/coreex-expert.md" DestSubPath=".claude/commands/coreex-expert.md" />
      <_AiFile Include="$(_RepoRoot).claude/commands/coreex-docs-sync.md" DestSubPath=".claude/commands/coreex-docs-sync.md" />
      <!-- Per-package AI usage guides: AGENTS.md renamed to <PackageName>.md -->
      <_AiFile Include="$(_RepoRoot)src/CoreEx/AGENTS.md" DestSubPath=".github/docs/coreex/agents/CoreEx.md" />
      <_AiFile Include="$(_RepoRoot)src/CoreEx.AspNetCore/AGENTS.md" DestSubPath=".github/docs/coreex/agents/CoreEx.AspNetCore.md" />
      <_AiFile Condition="Exists('$(_RepoRoot)src/CoreEx.AspNetCore.NSwag/AGENTS.md')" Include="$(_RepoRoot)src/CoreEx.AspNetCore.NSwag/AGENTS.md" DestSubPath=".github/docs/coreex/agents/CoreEx.AspNetCore.NSwag.md" />
