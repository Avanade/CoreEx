<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <Title>CoreEx 'dotnet new' template.</Title>
    <Description>Core 'dotnet new' template for scaffolding CoreEx-based projects.</Description>
    <PackageTags>coreex microservices domain-based event-driven railway-oriented reference-data</PackageTags>
    <PackageType>Template</PackageType>
  </PropertyGroup>

  <ItemGroup>
    <!-- Include all content files so VS can navigate them. -->
    <Content Include="content/**" PackagePath="content" />
    <!-- Un-pack the raw template.json files; version-stamped copies are packed by GenerateVersionedTemplateJson. -->
    <Content Update="content/**/.template.config/template.json" Pack="false" />
    <Content Update="content/CoreEx.Bootstrap/.template.config/template.json" Pack="true" />
  </ItemGroup>

  <ItemGroup>
    <!-- Exclude all content files from compilation; they are included as content only. -->
    <Compile Remove="content/**" />
  </ItemGroup>

  <!-- Inline task: replace a literal string in a file and write the result to a new path. -->
  <UsingTask TaskName="ReplaceTextInFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$([System.IO.Path]::Combine('$(MSBuildToolsPath)', 'Microsoft.Build.Tasks.Core.dll'))">
    <ParameterGroup>
      <SourceFile ParameterType="System.String" Required="true" />
      <DestinationFile ParameterType="System.String" Required="true" />
      <FindText ParameterType="System.String" Required="true" />
      <ReplaceText ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
        <![CDATA[
          string content = System.IO.File.ReadAllText(SourceFile);
          content = content.Replace(FindText, ReplaceText);
          System.IO.Directory.CreateDirectory(System.IO.Path.GetDirectoryName(DestinationFile) ?? string.Empty);
          System.IO.File.WriteAllText(DestinationFile, content);
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!-- Inline task: wraps the applyTo: frontmatter line in an instruction file with a template conditional
       so the coreex-ai template can scope all instruction files to a subfolder when app-folder is provided. -->
  <UsingTask TaskName="InjectAppFolderConditional" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$([System.IO.Path]::Combine('$(MSBuildToolsPath)', 'Microsoft.Build.Tasks.Core.dll'))">
    <ParameterGroup>
      <SourceFile ParameterType="System.String" Required="true" />
      <DestinationFile ParameterType="System.String" Required="true" />
      <PrependFrontmatter ParameterType="System.Boolean" Required="false" />
      <FrontmatterDescription ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
        <![CDATA[
          string content = System.IO.File.ReadAllText(SourceFile);
          if (PrependFrontmatter)
          {
              string desc = string.IsNullOrEmpty(FrontmatterDescription) ? "CoreEx framework conventions for this solution" : FrontmatterDescription;
              content = "---\napplyTo: \"**\"\ndescription: \"" + desc + "\"\n---\n\n" + content;
          }
          var lines = content.Split('\n');
          var sb = new System.Text.StringBuilder();
          bool transformed = false;
          foreach (var rawLine in lines)
          {
              var line = rawLine.TrimEnd('\r');
              if (!transformed && line.TrimStart().StartsWith("applyTo:"))
              {
                  // When app-folder is set, prefix the original pattern with the subfolder so each
                  // instruction file retains its own scope (e.g. **/*Validator*.cs stays targeted).
                  // When absent, preserve the original per-file applyTo pattern unchanged.
                  var colonIdx = line.IndexOf(':');
                  var originalPattern = line.Substring(colonIdx + 1).Trim().Trim('"');
                  // __COREEX_AI_APP_FOLDER_TOKEN__ is a sentinel, not the literal text "app-folder": the
                  // app-folder symbol's "replaces" value is a global text-replace across every packed file,
                  // so using the human-readable name here would also corrupt any prose mentioning "app-folder"
                  // (e.g. "--app-folder" in SKILL.md/README.md) elsewhere in the CoreEx.Ai bundle.
                  sb.AppendLine("<!-- #if hasAppFolder -->");
                  sb.AppendLine("applyTo: \"__COREEX_AI_APP_FOLDER_TOKEN__/" + originalPattern + "\"");
                  sb.AppendLine("<!-- #else -->");
                  sb.AppendLine(line);
                  sb.AppendLine("<!-- #endif -->");
                  transformed = true;
              }
              else
              {
                  sb.AppendLine(line);
              }
          }
          var destDir = System.IO.Path.GetDirectoryName(DestinationFile);
          if (!string.IsNullOrEmpty(destDir))
              System.IO.Directory.CreateDirectory(destDir);
          System.IO.File.WriteAllText(DestinationFile, sb.ToString());
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!-- Copy packaged AI context files from the CoreEx repo into the CoreEx.Bootstrap and CoreEx.Ai templates at pack time.
       CoreEx.Bootstrap receives the full set (including copilot-instructions.md and docs) for new-empty-repo scenarios.
       CoreEx.Ai receives instructions (transformed with app-folder conditionals), prompts, agents, Claude commands, the full skill suite (docs-sync, coreex-solution-scaffolder, and the L1 coreex-* skills), and the docs cache (architecture docs + per-package guides under .github/docs/coreex/) — no copilot-instructions.md.
       coreex (CoreEx.Core) no longer receives any .github/ AI assets; consumers run dotnet new coreex-ai separately.
       Files sourced for Bootstrap/Ai:
         - consumer-instructions/.github/copilot-instructions.md            → .github/copilot-instructions.md  (Bootstrap only)
         - consumer-instructions/.github/copilot-instructions.md            → .github/instructions/coreex.instructions.md (Ai only, generated at pack time with frontmatter prepended)
         - .github/coreex-ai-workflows.md                                    → .github/coreex-ai-workflows.md (Bootstrap and Ai)
         - .github/prompts/coreex-scaffold.prompt.md                        → .github/prompts/coreex-scaffold.prompt.md
         - .github/skills/coreex-solution-scaffolder/*                             → .github/skills/coreex-solution-scaffolder/ (Bootstrap and Ai)
         - .github/skills/coreex-docs-sync/*                                → .github/skills/coreex-docs-sync/ (Bootstrap and Ai)
         - .github/agents/coreex-expert.agent.md                           → .github/agents/coreex-expert.agent.md
         - .claude/commands/coreex-expert.md                               → .claude/commands/coreex-expert.md  (Bootstrap and Ai)
         - .claude/commands/coreex-docs-sync.md                            → .claude/commands/coreex-docs-sync.md (Bootstrap and Ai)
         - .github/instructions/*.instructions.md                           → .github/instructions/ (transformed for Ai; plain copy for Bootstrap)
         - docs/application-scaffolding-guide.md                           → .github/docs/coreex/... (Bootstrap only)
         - samples/docs/*.md                                                 → .github/docs/coreex/ (Bootstrap only)
         - src/CoreEx.*/AGENTS.md                                            → .github/docs/coreex/agents/ (Bootstrap only)
  -->
  <Target Name="CopyTemplateAiContext" BeforeTargets="_GetPackageFiles">
    <PropertyGroup>
      <_RepoRoot>$(MSBuildThisFileDirectory)../../</_RepoRoot>
      <_AiGenRoot>$(BaseIntermediateOutputPath)generated/CoreEx.Core/</_AiGenRoot>
      <_AiAiGenRoot>$(BaseIntermediateOutputPath)generated/CoreEx.Ai/</_AiAiGenRoot>
    </PropertyGroup>

    <!-- Clear previously generated AI assets so wildcard packing cannot pick up stale files. -->
    <RemoveDir Directories="$(_AiGenRoot)" />
    <RemoveDir Directories="$(_AiAiGenRoot)" />

    <!-- Files for CoreEx.Bootstrap (full set: copilot-instructions, skills, docs, per-package agents, everything). -->
