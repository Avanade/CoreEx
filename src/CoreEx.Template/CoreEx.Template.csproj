    <InjectAppFolderConditional SourceFile="$(_RepoRoot).github/instructions/coreex-host-setup.instructions.md" DestinationFile="$(_AiAiGenRoot).github/instructions/coreex-host-setup.instructions.md" />
    <InjectAppFolderConditional SourceFile="$(_RepoRoot).github/instructions/coreex-repositories.instructions.md" DestinationFile="$(_AiAiGenRoot).github/instructions/coreex-repositories.instructions.md" />
