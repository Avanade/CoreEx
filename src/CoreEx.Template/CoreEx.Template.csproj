    </ItemGroup>

    <!-- Copy Bootstrap files in one batch. -->
    <Copy SourceFiles="@(_AiFile)" DestinationFiles="@(_AiFile->'$(_AiGenRoot)%(DestSubPath)')" SkipUnchangedFiles="true" />

    <!-- Bootstrap: pack everything generated into content\CoreEx.Bootstrap\. -->
    <ItemGroup>
      <_BootstrapAiGenerated Include="$(_AiGenRoot)**/*" Exclude="$(_AiGenRoot).template.config/template.json" />
      <None Include="@(_BootstrapAiGenerated)" Pack="true" PackagePath="content/CoreEx.Bootstrap/%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>

    <!-- CoreEx.Ai: transform instruction files to inject the app-folder conditional into their applyTo frontmatter,
         then copy prompts, agents, and Claude commands directly (no conditional needed there). -->
    <InjectAppFolderConditional SourceFile="$(_RepoRoot)consumer-instructions/.github/copilot-instructions.md" DestinationFile="$(_AiAiGenRoot).github/instructions/coreex.instructions.md" PrependFrontmatter="true" />
    <InjectAppFolderConditional SourceFile="$(_RepoRoot).github/instructions/coreex-api-controllers.instructions.md" DestinationFile="$(_AiAiGenRoot).github/instructions/coreex-api-controllers.instructions.md" />
