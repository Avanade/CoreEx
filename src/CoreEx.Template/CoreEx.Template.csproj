    <!-- CoreEx.Ai: bake the docs-cache manifest with a sentinel token. The template's own "coreex-version"
         constant symbol (see content/CoreEx.Ai/.template.config/template.json) replaces the sentinel with the
         real installed version at the consumer's `dotnet new coreex-ai` generation time — the same two-stage
         mechanism CoreEx.Core/Api/Relay/Subscribe already use to pin _Directory.Packages.props. A dedicated
         sentinel (not the literal words "coreex-version") is required here because the symbol's text-replace
         scans every file in the template's content: if the manifest used "coreex-version" as both the replace
         target AND its own human-readable field name, every other place that field name is mentioned in prose
         (SKILL.md, README.md, coreex-expert.agent.md) would also get silently rewritten to the version number.
         This makes the AI-asset bundle self-describing (which CoreEx.Template release populated it) without
         requiring a first manual sync, and is what /coreex-docs-sync reads to detect a version mismatch. -->
    <ItemGroup>
      <_AiManifestLine Include="# Generated by 'dotnet new coreex-ai' — records which CoreEx.Template release populated" />
      <_AiManifestLine Include="# .github/instructions, .github/skills, .github/prompts, .github/agents, and this docs cache." />
      <_AiManifestLine Include="# Do not hand-edit — refreshed automatically by 'dotnet new coreex-ai --force'." />
      <_AiManifestLine Include="coreex-version: __COREEX_AI_VERSION_TOKEN__" />
    </ItemGroup>
    <WriteLinesToFile File="$(_AiAiGenRoot).github/docs/coreex/manifest.txt" Lines="@(_AiManifestLine)" Overwrite="true" Encoding="UTF-8" />

    <!-- CoreEx.Ai: pack all generated files into content\CoreEx.Ai\. -->
    <ItemGroup>
      <_CoreExAiGenerated Include="$(_AiAiGenRoot)**/*" />
      <None Include="@(_CoreExAiGenerated)" Pack="true" PackagePath="content/CoreEx.Ai/%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>
  </Target>

  <!-- Stamp the CoreEx version into each template.json before the nupkg is assembled.
       BeforeTargets="_GetPackageFiles" ensures the items are visible when NuGet collects pack content. -->
  <Target Name="GenerateVersionedTemplateJson" BeforeTargets="_GetPackageFiles">
    <PropertyGroup>
      <_GenRoot>$(BaseIntermediateOutputPath)generated/</_GenRoot>
    </PropertyGroup>
    <ReplaceTextInFile SourceFile="$(MSBuildThisFileDirectory)content/CoreEx.Ai/.template.config/template.json" DestinationFile="$(_GenRoot)CoreEx.Ai/.template.config/template.json" FindText="COREEX_VERSION" ReplaceText="$(Version)" />
    <ReplaceTextInFile SourceFile="$(MSBuildThisFileDirectory)content/CoreEx.Core/.template.config/template.json" DestinationFile="$(_GenRoot)CoreEx.Core/.template.config/template.json" FindText="COREEX_VERSION" ReplaceText="$(Version)" />
    <ReplaceTextInFile SourceFile="$(MSBuildThisFileDirectory)content/CoreEx.Api/.template.config/template.json" DestinationFile="$(_GenRoot)CoreEx.Api/.template.config/template.json" FindText="COREEX_VERSION" ReplaceText="$(Version)" />
    <ReplaceTextInFile SourceFile="$(MSBuildThisFileDirectory)content/CoreEx.Relay/.template.config/template.json" DestinationFile="$(_GenRoot)CoreEx.Relay/.template.config/template.json" FindText="COREEX_VERSION" ReplaceText="$(Version)" />
    <ReplaceTextInFile SourceFile="$(MSBuildThisFileDirectory)content/CoreEx.Subscribe/.template.config/template.json" DestinationFile="$(_GenRoot)CoreEx.Subscribe/.template.config/template.json" FindText="COREEX_VERSION" ReplaceText="$(Version)" />
    <ItemGroup>
      <None Include="$(_GenRoot)CoreEx.Ai/.template.config/template.json" Pack="true" PackagePath="content/CoreEx.Ai/.template.config/template.json" />
      <None Include="$(_GenRoot)CoreEx.Core/.template.config/template.json" Pack="true" PackagePath="content/CoreEx.Core/.template.config/template.json" />
      <None Include="$(_GenRoot)CoreEx.Api/.template.config/template.json" Pack="true" PackagePath="content/CoreEx.Api/.template.config/template.json" />
      <None Include="$(_GenRoot)CoreEx.Relay/.template.config/template.json" Pack="true" PackagePath="content/CoreEx.Relay/.template.config/template.json" />
      <None Include="$(_GenRoot)CoreEx.Subscribe/.template.config/template.json" Pack="true" PackagePath="content/CoreEx.Subscribe/.template.config/template.json" />
    </ItemGroup>
  </Target>

