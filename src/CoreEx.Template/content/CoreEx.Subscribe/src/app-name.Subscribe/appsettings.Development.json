{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Azure": "Warning",
      "Microsoft": "Warning",
//#if implement-sqlserver
      "Npgsql": "Warning",
//#endif
//#if implement-servicebus
      "Azure.Messaging.ServiceBus": "Critical",
      "CoreEx.Azure.Messaging.ServiceBus": "Warning",
//#endif
      "ZiggyCreatures": "Warning",
      "StackExchange": "Warning"
    }
  },
  "Aspire": {
//#if implement-sqlserver
    "Microsoft": {
      "Data": {
        "SqlClient": {
          "ConnectionString": "Data Source=127.0.0.1,1433;Initial Catalog=domain-name;User id=sa;Password=yourStrong(!)Password;TrustServerCertificate=true"
        }
      }
    },
//#elif implement-postgres
    "Npgsql": {
      "ConnectionString": "Server=127.0.0.1;Database=domain-name-lower;Username=postgres;Password=yourStrong#!Password"
    },
//#endif
//#if implement-servicebus
    "Azure": {
      "Messaging": {
        "ServiceBus": {
          "ConnectionString": "Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;",
          "QueueOrTopicName": "domain-parent-lower",
          "SubscriptionName": "domain-name-lower"
        }
      }
    },
//#endif
    "StackExchange": {
      "Redis": {
        "ConnectionString": "localhost:6379",
        "ConfigurationOptions": {
          "ConnectTimeout": 3000,
          "ConnectRetry": 2
        }
      }
    }
  }
}