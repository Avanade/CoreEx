{
  "$schema": "http://json.schemastore.org/template",
  "author": "https://github.com/avanade/coreex",
  "classifications": [ "CoreEx", "Microservice", "Application" ],
  "identity": "CoreEx.Solution",
  "name": "CoreEx Application Services",
  "description": "A solution template for the core application services, tooling, and test projects using CoreEx.",
  "shortName": "coreex",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "app-name",
  "preferNameDirectory": false,
  "symbols": {
    "coreex-version": {
      "type": "generated",
      "generator": "constant",
      "parameters": {
        "value": "COREEX_VERSION"
      },
      "replaces": "coreex-version"
    },
    "domain-name": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "ValueAfterLastDotDelimited",
      "fileRename": "domain-name",
      "replaces": "domain-name"
    },
    "domain-name-lower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "ValueAfterLastDotDelimitedLower",
      "replaces": "domain-name-lower"
    },
    "db-name": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "ValueAfterLastDotDelimitedLower",
      "fileRename": "db-name",
      "replaces": "db-name"
    },
    "solution-name": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "ValueWithoutLastDotDelimited",
      "fileRename": "solution-name",
      "replaces": "solution-name"
    },
    "date-now": {
      "type": "generated",
      "generator": "now",
      "parameters": {
        "format": "yyyyMMdd"
      },
      "fileRename": "date-now",
      "replaces": "date-now"
    },
    "refdata-enabled": {
      "type": "parameter",
      "datatype": "bool",
      "displayName": "Reference data enabled",
      "description": "Indicates whether reference data pattern/capabilities is enabled.",
      "defaultValue": "true"
    },
    "rop-enabled": {
      "type": "parameter",
      "datatype": "bool",
      "displayName": "ROP enabled",
      "description": "Indicates whether Railway-oriented Programming (ROP), being Result/Result<T>, is enabled.",
      "defaultValue": "false"
    },
    "domain-driven-enabled": {
      "type": "parameter",
      "datatype": "bool",
      "displayName": "Domain-driven project enabled",
      "description": "Indicates whether a Domain-driven project is enabled.",
      "defaultValue": "false"
    },
    "data-provider": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        {
          "choice": "SqlServer",
          "displayName": "SQL Server",
          "description": "Indicates to use SQL Server as the data provider."
        },
        {
          "choice": "Postgres",
          "displayName": "PostgreSQL",
          "description": "Indicates to use PostgreSQL as the data provider."
        },
        {
          "choice": "None",
          "displayName": "None",
          "description": "Indicates no data provider is used (e.g. a facade over an external system such as Dynamics 365)."
        }
      ],
      "defaultValue": "SqlServer",
      "displayName": "Data provider",
      "description": "Determines the data provider technology to use."
    },
    "implement-sqlserver": {
      "type": "computed",
      "value": "data-provider == 'SqlServer'"
    },
    "implement-postgres": {
      "type": "computed",
      "value": "data-provider == 'Postgres'"
    },
    "implement-none-data": {
      "type": "computed",
      "value": "data-provider == 'None'"
    },
    "outbox-enabled": {
      "type": "parameter",
      "datatype": "bool",
      "displayName": "Outbox enabled",
      "description": "Indicates whether a transactional-outbox is enabled.",
      "defaultValue": "true"
    },
    "messaging-provider": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        {
          "choice": "ServiceBus",
          "displayName": "Azure Service Bus",
          "description": "Indicates to use Azure Service Bus as the messaging provider."
        },
        {
          "choice": "None",
          "displayName": "None",
          "description": "Indicates no messaging provider is used."
        }
      ],
      "defaultValue": "ServiceBus",
      "displayName": "Messaging provider",
      "description": "Determines the messaging provider technology to use."
    },
    "implement-servicebus": {
      "type": "computed",
      "value": "messaging-provider == 'ServiceBus'"
    },
    "implement-none-messaging": {
      "type": "computed",
      "value": "messaging-provider == 'None'"
    }
  },
  "sources": [
    {
      "rename": {
        "_Directory.Build.props": "Directory.Build.props",
        "_Directory.Packages.props": "Directory.Packages.props",
        "_editorconfig": ".editorconfig",
        "_gitignore": ".gitignore",
        "_.filenesting.json": ".filenesting.json"
      },
      "modifiers": [
        {
          "condition": "(!refdata-enabled)",
          "exclude": [
            "src/app-name.Infrastructure/Repositories/ReferenceDataRepository.cs",
            "src/app-name.Application/Repositories/IReferenceDataRepository.cs",
            "src/app-name.Application/ReferenceDataService.cs",
            "tools/app-name.CodeGen/**",
            "tools/app-name.Database/Data/ref-data.yaml"
          ]
        },
        {
          "condition": "(!domain-driven-enabled)",
          "exclude": [ "src/app-name.Domain/**" ]
        },
        {
          "condition": "(implement-none-data)",
          "exclude": [
            "tools/app-name.Database/**",
            "tools/app-name.CodeGen/**",
            "src/app-name.Infrastructure/Repositories/domain-nameDbContext.cs",
            "src/app-name.Infrastructure/Repositories/domain-nameEfDb.cs",
            "tests/app-name.Test.Common/Data/**"
          ]
        },
        {
          "condition": "(implement-sqlserver)",
          "exclude": [ "tools/app-name.Database/Migrations/*.pgsql" ]
        },
        {
          "condition": "(implement-postgres)",
          "exclude": [ "tools/app-name.Database/Migrations/*.sql" ]
        },
        {
          "condition": "(!outbox-enabled)",
          "exclude": [ "tools/app-name.Database/Migrations/*outbox-tables.*" ]
        }
      ]
    }
  ],
  "specialCustomOperations": {
    "*.md": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "actionableIf": [ "<!-- #if" ],
            "actionableElse": [ "<!-- #else" ],
            "actionableElseif": [ "<!-- #elseif", "<!-- #elif" ],
            "endif": [ "<!-- #endif" ],
            "trim": true,
            "wholeLine": true
          }
        }
      ]
    },
    "*.slnx": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "actionableIf": [ "<!--#if" ],
            "actionableElse": [ "<!--#else" ],
            "actionableElseif": [ "<!--#elseif", "<!--#elif" ],
            "endif": [ "<!--#endif" ],
            "trim": true,
            "wholeLine": true
          }
        }
      ]
    }
  },
  "forms": {
    "ValueAfterLastDotDelimited": {
      "identifier": "replace",
      "pattern": "^.*\\.([^\\.]+)$", // regex to capture the last segment in a dot-delimited string (e.g. "Foo.Bar.App.Blah" → "Blah", "App.Blah" → "Blah", "Blah" → "Blah").
      "replacement": "$1" // replace with the captured last segment.
    },
    "ValueSecondToLastDotDelimited": {
      "identifier": "replace",
      "pattern": "^(?:.*\\.)?([^.]+)\\.[^.]+$", // regex to capture the second-to-last segment in a dot-delimited string (e.g. "Foo.Bar.App.Blah" → "App", "App.Blah" → "App", "Blah" → "Blah").
      "replacement": "$1" // replace it with the captured second-to-last or last (depending) segment.
    },
    "ValueWithoutLastDotDelimited": {
      "identifier": "replace",
      "pattern": "^(.*)\\.([^.]+)$", // regex to capture everything before the last dot-delimiter (e.g. "Foo.Bar.App.Blah" → "Foo.Bar.App", "App.Blah" → "App", "Blah" → "Blah").
      "replacement": "$1" // replace it with everything before the last dot-delimited segment.
    },
    "LowerCase": {
      "identifier": "lowerCase"
    },
    "ValueAfterLastDotDelimitedLower": {
      "identifier": "chain",
      "steps": [ "ValueAfterLastDotDelimited", "LowerCase" ]
    }
  }
}